# Copy this file to .env and fill in your own values before running the app.
# Never commit the actual .env file — it contains secrets.

# Flask secret key (generate any long random string)
SECRET_KEY=change-this-to-a-long-random-string

# Email account used to send OTP password-reset emails (Gmail recommended)
MAIL_USERNAME=youremail@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# M-Pesa Daraja API credentials (sandbox or production)
# Leave blank if you are not using the payment feature
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BUSINESS_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_ENVIRONMENT=sandbox
